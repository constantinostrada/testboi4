{
  "name": "testboi4",
  "version": "1.0.0",
  "description": "A modern, production-ready web application built with vanilla HTML, CSS, and JavaScript",
  "main": "src/js/app.js",
  "scripts": {
    "start": "npx http-server public -p 8080 -o",
    "lint": "eslint src/js/**/*.js",
    "lint:fix": "eslint src/js/**/*.js --fix",
    "format": "prettier --write \"**/*.{js,css,html,md}\"",
    "format:check": "prettier --check \"**/*.{js,css,html,md}\"",
    "validate": "npm run format:check && npm run lint"
  },
  "keywords": [
    "html",
    "css",
    "javascript",
    "vanilla-js",
    "boilerplate"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "http-server": "^14.1.1",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
